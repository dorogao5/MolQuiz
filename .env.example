MOLQUIZ_TELEGRAM_TOKEN=replace-me
MOLQUIZ_DATABASE_URL=postgresql+asyncpg://molquiz:molquiz@localhost:15432/molquiz
MOLQUIZ_REDIS_URL=redis://localhost:16379/0
MOLQUIZ_OPSIN_BASE_URL=http://localhost:18080
MOLQUIZ_STORAGE_DIR=/app/storage
MOLQUIZ_ENVIRONMENT=development
MOLQUIZ_LOG_LEVEL=INFO
MOLQUIZ_QWEN_COMMAND=

# Порты, которые Docker Compose публикует на localhost.
# Если на машине уже заняты 15432/16379/18080, просто поменяй значения.
MOLQUIZ_POSTGRES_HOST_PORT=15432
MOLQUIZ_REDIS_HOST_PORT=16379
MOLQUIZ_OPSIN_HOST_PORT=18080

# Нужно только если хочешь запускать webhook-режим через отдельный профиль prod.
MOLQUIZ_TELEGRAM_WEBHOOK_SECRET=
MOLQUIZ_TELEGRAM_WEBHOOK_BASE_URL=
